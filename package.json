{
  "name": "smoketest",
  "version": "1.0.1",
  "private": true,
  "description": "A cross-provider coding assistant for Responses API compatible providers.",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit": "npm audit --omit=dev --audit-level=high",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test:coverage",
    "build:electron": "npm run build && node scripts/prepare-electron.cjs",
    "electron": "npm run build:electron && electron electron/main.cjs",
    "electron:run": "electron electron/main.cjs",
    "electron:pack": "npm run build:electron && electron-builder --dir",
    "electron:dist": "npm run build:electron && electron-builder --publish never",
    "electron:dist:linux": "npm run build:electron && electron-builder --linux AppImage --x64 --publish never",
    "electron:dist:win": "npm run build:electron && electron-builder --win nsis --x64 --publish never",
    "electron:dist:mac": "npm run build:electron && electron-builder --mac --x64 --arm64 --publish never"
  },
  "dependencies": {
    "marked": "^18.0.6",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.5",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.9.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "next": {
      "postcss": "^8.5.10"
    }
  },
  "build": {
    "appId": "com.h1ddenpr0cess20.smoketest",
    "productName": "smoketest",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/main.cjs",
      "electron/preload.cjs",
      "electron/icon.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "electron/icon.png"
    },
    "linux": {
      "category": "Development",
      "target": [
        "AppImage"
      ],
      "icon": "electron/icon.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "electron/icon.png"
    }
  }
}
